root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
# ktlint configuration (read natively by the ktlint Gradle plugin).
ktlint_code_style = intellij_idea
# Jetpack Compose: @Composable functions use PascalCase by design.
ktlint_function_naming_ignore_when_annotated_with = Composable
# Allow grouping related declarations (e.g. dispatcher qualifiers) in one file.
ktlint_standard_filename = disabled

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
